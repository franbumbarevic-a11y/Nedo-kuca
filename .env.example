# ─────────────────────────────────────────────────────────────────────────────
# Template of required environment variables. NO real secrets here.
# Copy to .env.local (gitignored) and fill in real values, then paste the same
# values into Vercel → Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────────────────────

# Gmail account that sends booking enquiry emails
EMAIL_USER=

# Gmail app password — https://myaccount.google.com/apppasswords
EMAIL_PASS=

# Where booking enquiries are delivered (often same as EMAIL_USER)
EMAIL_TO=

# Airbnb iCal export URL (Airbnb → Calendar → Availability → Export Calendar)
AIRBNB_ICAL_URL=
